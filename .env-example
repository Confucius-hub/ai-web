DATABASE_URL="postgresql+asyncpg://postgres:root@localhost:5433/ai_web_db"

# LLM configuration
# LLM_MODE: "mock" (default) — uses MockLLM, "real" — uses external LLM provider
LLM_MODE="mock"

# Required when LLM_MODE="real"
LLM_API_KEY="your-openrouter-api-key"
LLM_MODEL="google/gemma-3-1b-it:free"
LLM_BASE_URL="https://openrouter.ai/api/v1"
