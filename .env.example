# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_web_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full DSN (used by app and alembic inside containers)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_web_db

# === Redis (broker & cache) ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === LLM ===
# mode: mock | real | local_onnx (local_onnx used for intent classification, not chat)
LLM_MODE=mock
LLM_API_KEY=replace_with_your_openrouter_key
LLM_MODEL=google/gemma-3-1b-it:free
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MAX_NEW_TOKENS=256
LLM_TIMEOUT_SECONDS=30

# === Local ONNX intent classifier ===
LOCAL_MODEL_PATH=/app/models/intent_classifier.onnx
LOCAL_VECTORIZER_PATH=/app/models/tfidf_vectorizer.onnx
LOCAL_LABELS_PATH=/app/models/labels.json

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
APP_ENV=production

# === UI ===
UI_PORT=8501
# How UI talks to API (through nginx)
API_BASE_URL=http://nginx/api

# === Grafana ===
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
