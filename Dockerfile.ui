# syntax=docker/dockerfile:1.7
# # Оптимизация сборок — отдельный легковесный образ для UI (только streamlit + httpx)
FROM python:3.11-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_SYSTEM_PYTHON=1

RUN pip install --no-cache-dir uv==0.5.5

WORKDIR /app

# Только минимум для UI (без sqlalchemy / celery / onnx)
RUN uv pip install --system --no-cache \
    "streamlit>=1.39.0" \
    "httpx[http2]>=0.27.0" \
    "pandas>=2.2.0" \
    "plotly>=5.24.0"


FROM python:3.11-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

STOPSIGNAL SIGTERM

RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/lib/python3.11 /usr/local/lib/python3.11
COPY --from=builder /usr/local/bin /usr/local/bin

WORKDIR /app
COPY ui ./ui

EXPOSE 8501

# # Graceful Shutdown — Streamlit штатно ловит SIGTERM
CMD ["streamlit", "run", "ui/app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true", \
     "--browser.gatherUsageStats=false"]
